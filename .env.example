# Firebase Configuration
# Get these values from your Firebase Console:
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Auth emulator (local testing)
# VITE_USE_FIREBASE_EMULATOR=true
#
# Open the app at http://127.0.0.1:5173 (not localhost) so Firebase Auth's
# reCAPTCHA/authorized-domain checks behave consistently.

# API Configuration
VITE_API_BASE_URL=

# Backend environment header (sent as x-environment on every API request).
VITE_API_ENVIRONMENT=staging

# Optional override for Firestore client database. If unset, derived from VITE_API_ENVIRONMENT
# (staging → "staging", otherwise default).
# VITE_FIREBASE_DATABASE_ID=staging
